{
  "name": "@outseta/api-client",
  "version": "0.2.0",
  "description": "Generated API client for the Outseta REST API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/outseta/outseta-js.git",
    "directory": "packages/api-client"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --packages external",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ignore-pattern generated",
    "test": "bun test --env-file ../../.env.test"
  },
  "dependencies": {
    "ky": "^1.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
