{
  "name": "@outseta/node-sdk",
  "version": "0.0.0",
  "description": "Node.js SDK for the Outseta API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@outseta/api-client": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  }
}
