{
  "name": "@outseta/node-sdk",
  "version": "0.0.0",
  "description": "Node.js SDK for the Outseta API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --packages external",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@outseta/api-client": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "access": "public"
  }
}
