{
  "name": "@outseta/react",
  "version": "0.1.0",
  "description": "React hooks and components for the Outseta API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/outseta/outseta-js.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --format esm --packages external",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ignore-pattern generated"
  },
  "dependencies": {
    "@outseta/api-client": "*",
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
