    "typecheck": "nx run-many -t typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "nx": "^20.0.0",
    "orval": "^7.0.0",
    "typescript": "^5.7.0"
  }
}
